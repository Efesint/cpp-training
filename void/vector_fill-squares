#include <iostream>
#include <vector>

void fill_squares(std::vector<int>& v, int n)
{
   for(int i = 1; i <= n; ++i)
   {
       v.push_back(i*i);
   }

}

int main()
{
std::vector<int> v;
int n = 5;
fill_squares(v, n);
for(int i = 0; i < v.size(); ++i)
{
   std::cout << v[i] << " ";
}
return 0;
}
